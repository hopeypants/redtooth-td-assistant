{
  "manifest_version": 3,
  "key": "",
  "name": "Redtooth TD Assistant",
  "version": "0.8.116",
  "description": "Adds functionality to the Redtooth venue admin Tournament Director area.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon16.png",
        "icons/icon24.png",
        "icons/icon32.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": [
        "https://www.redtoothpoker.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "Redtooth TD Assistant",
    "default_popup": "src/options/options.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.redtoothpoker.com/venue_admin/*"
      ],
      "js": [
        "src/content/venue-admin.ts"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": false
  }
}
